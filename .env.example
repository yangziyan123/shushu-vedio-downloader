APP_ENV=production
FRONTEND_PORT=8080
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DATA_DIR=/app/data
DOWNLOAD_DIR=/app/data/downloads

# Docker build mirrors.
# Base images are still resolved by Docker daemon. Configure registry-mirrors on the server
# or replace these with mirrored/private image names when needed.
PYTHON_IMAGE=python:3.12-slim
NODE_IMAGE=node:24-alpine
NGINX_IMAGE=nginx:1.27-alpine
APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
APT_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com
